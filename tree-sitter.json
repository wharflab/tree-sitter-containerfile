{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "containerfile",
      "camelcase": "Containerfile",
      "scope": "source.containerfile",
      "path": ".",
      "file-types": [
        "Containerfile",
        "containerfile",
        "Dockerfile",
        "dockerfile",
        "docker",
        "container"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^(containerfile|dockerfile|docker)$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0 AND MIT",
    "description": "A Containerfile and Dockerfile grammar for tree-sitter",
    "authors": [
      {
        "name": "WharfLab"
      },
      {
        "name": "Camden Cheek",
        "email": "camden@ccheek.com"
      }
    ],
    "links": {
      "repository": "https://github.com/wharflab/tree-sitter-containerfile"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
